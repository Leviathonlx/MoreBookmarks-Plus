 487 |  RICE_sri_lanka_aspiration_vijayabahu_desc: "\n\n#bold [historical_aspiration_main_objectives|E]#!\n$EFFECT_LIST_BULLET$Be the [king|E] of [GetTitleByKey('k_lanka').GetNameNoTier]\n$EFFECT_LIST_BULLET$Take the [decision|E] to $RICE_sri_lanka_polonnaruwa_capital$\n$EFFECT_LIST_BULLET$Remain Buddhist\n\n#bold Rewards#!\n$EFFECT_LIST_BULLET$Gain @prestige_icon! #V [EmptyScope.ScriptValue('RICE_aspiration_medium_resource_bonus')]#! [prestige|E]\n$EFFECT_LIST_BULLET$Receive #V 500#! [GetMaA('RICE_velakkara').GetName] [special_troops|E]\n$EFFECT_LIST_BULLET$Every [county|E] in [GetGeographicalRegion('RICE_sri_lanka_alt_region').GetName] gains @development_icon! #V [EmptyScope.ScriptValue('RICE_red_sea_al_umari_aspiration_dev_bonus')]#! [development|E]\n\n#bold [historical_aspiration_bonus_objectives|E]#!\n$EFFECT_LIST_BULLET$Take the [decision|E] to $RICE_india_irrigation_tank_decision$ at least once (Reward: @prestige_icon! #V [EmptyScope.ScriptValue('RICE_aspiration_medium_resource_bonus')]#! [prestige|E])\n$EFFECT_LIST_BULLET$Take the [decision|E] to $RICE_sri_lanka_support_monastery$ at least once (Reward: @piety_icon! #V [EmptyScope.ScriptValue('RICE_aspiration_medium_resource_bonus')]#! [piety|E])"
     |                                                                                                                                                                                                                                                                                                                                                                                                      ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ 

132 |  RICE_tarim_basin_aspiration_yelu_yixin_desc: "\n\n#bold [historical_aspiration_main_objectives|E]#!\n$EFFECT_LIST_BULLET$Be a [direct_vassal|E] of [GetTitleByKey('e_great_liao').GetNameNoTier]\n$EFFECT_LIST_BULLET$Have at least [gold_i|E] #V [EmptyScope.ScriptValue('RICE_aspiration_large_resource_bonus')]#! in your treasury\n$EFFECT_LIST_BULLET$Xiao Guanyin and any and all of her [children|E] are dead\n$EFFECT_LIST_BULLET$Ensure the [ruler|E] of [GetTitleByKey('e_great_liao').GetNameNoTier] has at least #P 25#! [opinion|E] of you\n$EFFECT_LIST_BULLET$Have a [prestige_level|E] of [GetModifier( 'prestige_level_3' ).GetNameWithTooltip|L] or higher\n\n#bold Rewards#!\n$EFFECT_LIST_BULLET$Gain a [diplomacy_lifestyle|E] [perk|E]\n$EFFECT_LIST_BULLET$Gain a [intrigue_lifestyle|E] [perk|E]\n$EFFECT_LIST_BULLET$Gain @prestige_icon! #V [EmptyScope.ScriptValue('RICE_aspiration_large_resource_bonus')]#! [prestige|E]\n$EFFECT_LIST_BULLET$Upgrade the [GetTrait('education_intrigue_4').GetName( GetNullCharacter )|U] [trait|E] to the [GetTrait('education_intrigue_5').GetName( GetNullCharacter )|U] [trait|E]\n$EFFECT_LIST_BULLET$Gain a [perpetual_hook|E] on the [ruler|E] of [GetTitleByKey('e_great_liao').GetNameNoTier]\n\n#bold [historical_aspiration_bonus_objectives|E]#!\n$EFFECT_LIST_BULLET$Directly kill Xiao Guanyin (Reward: Gain a [intrigue_lifestyle|E] [perk|E])\n$EFFECT_LIST_BULLET$Have [dread_i|E] #V [EmptyScope.ScriptValue('high_dread')]#! [dread|E] or higher (Reward: Receive #V 1000#! $heritage_chinese_name$ [special_troops|E], including some [men_at_arms|E])"
    |                                                           ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ 

